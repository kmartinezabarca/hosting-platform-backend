# ─────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="ROKE Industries"
APP_ENV=testing
APP_KEY=base64:2fl+Lgb7bxHOKZ6YmTSTtsFpIXwPkBhGwu4F9G3OVJE=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
COMPANY_LOGO_URL="${APP_URL}/server-icon.png"

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS — apunta al MySQL del sidecar CI
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hosting_platform_test
DB_USERNAME=laravel
DB_PASSWORD=secret

ROKEPET_DB_HOST=127.0.0.1
ROKEPET_DB_PORT=3306
ROKEPET_DB_DATABASE=hosting_platform_test
ROKEPET_DB_USERNAME=laravel
ROKEPET_DB_PASSWORD=secret

# ─────────────────────────────────────────────────────────────────────────────
# CACHE / COLAS / SESIÓN — array para tests (sin Redis)
# ─────────────────────────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# CORREO — log para tests
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=soporte@rokeindustries.com
MAIL_FROM_NAME="ROKE Industries"

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE — keys de test dummy (evitan el error de AuthenticationException)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_dummy_ci_key
STRIPE_SECRET=sk_test_dummy_ci_key
STRIPE_WEBHOOK_SECRET=whsec_dummy_ci_secret

# ─────────────────────────────────────────────────────────────────────────────
# COOLIFY — dummy para CI
# ─────────────────────────────────────────────────────────────────────────────
COOLIFY_URL=http://localhost:8000
COOLIFY_API_TOKEN=dummy_token_for_ci
COOLIFY_TEAM_ID=0
COOLIFY_SERVER_UUID=dummy-uuid

# ─────────────────────────────────────────────────────────────────────────────
# BILLING
# ─────────────────────────────────────────────────────────────────────────────
BILLING_TAX_RATE_PERCENT=16.00
RECEIPT_PREFIX=REC-

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD / CORS / SANCTUM
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DOMAIN=localhost

# ─────────────────────────────────────────────────────────────────────────────
# REVERB — dummy para CI
# ─────────────────────────────────────────────────────────────────────────────
REVERB_APP_ID=hosting-platform
REVERB_APP_KEY=dummy-reverb-key
REVERB_APP_SECRET=dummy-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─────────────────────────────────────────────────────────────────────────────
# PTERODACTYL — dummy para CI
# ─────────────────────────────────────────────────────────────────────────────
PTERODACTYL_URL=https://panel.dummy.com
PTERODACTYL_API_KEY=dummy_key
PTERODACTYL_CLIENT_API_KEY=dummy_client_key
PTERODACTYL_DEFAULT_NODE=1
PTERODACTYL_WINGS_INTERNAL_URL=http://localhost:8080
PTERODACTYL_WINGS_PUBLIC_URL=https://wings.dummy.com

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE — dummy para CI
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=dummy_token
CLOUDFLARE_ZONE_ID=dummy_zone_id
CLOUDFLARE_ZONE_NAME=rokeindustries.com
CLOUDFLARE_MINECRAFT_SRV_TARGET=mc.rokeindustries.com

# ─────────────────────────────────────────────────────────────────────────────
# ROKE.PET — dummy para CI
# ─────────────────────────────────────────────────────────────────────────────
ROKEPET_FRONTEND_URL=https://roke.pet
ROKEPET_STRIPE_SECRET=
ROKEPET_STRIPE_WEBHOOK_SECRET=
ROKEPET_STRIPE_PRICE_STARTER=price_dummy
ROKEPET_STRIPE_PRICE_PRO=price_dummy
ROKEPET_TRIAL_DAYS=14
ROKEPET_VAPID_PUBLIC_KEY=dummy
ROKEPET_VAPID_PRIVATE_KEY=dummy
ROKEPET_VAPID_SUBJECT=mailto:soporte@rokeindustries.com

# ─────────────────────────────────────────────────────────────────────────────
# SWAGGER
# ─────────────────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=false
# -----------------------------------------------------------------------------
# GITHUB APP - dummies para CI; los tests que firman JWT generan su propia
# llave RSA en setUp() y la inyectan via config()
# -----------------------------------------------------------------------------
GITHUB_APP_ID=12345
GITHUB_APP_SLUG=roke-platform-test
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=test-webhook-secret
