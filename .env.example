# ─────────────────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="ROKE Industries"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
COMPANY_LOGO_URL="${APP_URL}/server-icon.png"

# ─────────────────────────────────────────────────────────────────────────────
# COOLIFY — despliegue de hosting (sitios web)
# ─────────────────────────────────────────────────────────────────────────────
# Sin defaults en codigo: cada entorno DEBE definir su propia URL e IPs.
COOLIFY_URL=http://coolify.internal:8000
# IP destino de los registros A de DNS para sitios de hosting (Cloudflare)
COOLIFY_HOSTING_DNS_IP=
COOLIFY_API_TOKEN=
COOLIFY_TEAM_ID=0
COOLIFY_SERVER_UUID=
# Dominio base de los subdominios automaticos: {usuario}.{HOSTING_BASE_DOMAIN}
# dev => rokeindustries.dev | prod => rokeindustries.com. Debe existir como
# zona en Cloudflare (CLOUDFLARE_ZONE_NAME) o el registro A del subdominio falla.
# Si se deja vacio, hereda de CLOUDFLARE_ZONE_NAME.
HOSTING_BASE_DOMAIN=rokeindustries.dev
# Health check enviado a Coolify al crear apps. Si COOLIFY_HEALTH_CHECK_PORT se
# deja vacio, se usa el primer puerto expuesto del recurso.
COOLIFY_HEALTH_CHECK_ENABLED=true
COOLIFY_HEALTH_CHECK_PATH=/
COOLIFY_HEALTH_CHECK_PORT=
COOLIFY_HEALTH_CHECK_HOST=
COOLIFY_HEALTH_CHECK_METHOD=GET
COOLIFY_HEALTH_CHECK_RETURN_CODE=200
COOLIFY_HEALTH_CHECK_SCHEME=http
COOLIFY_HEALTH_CHECK_RESPONSE_TEXT=
COOLIFY_HEALTH_CHECK_INTERVAL=30
COOLIFY_HEALTH_CHECK_TIMEOUT=10
COOLIFY_HEALTH_CHECK_RETRIES=3
COOLIFY_HEALTH_CHECK_START_PERIOD=30

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB APP — integración de repositorios (plano de cómputo)
# GITHUB_APP_PRIVATE_KEY_BASE64: PEM de la App en base64 (`base64 -w0 key.pem`)
# GITHUB_WEBHOOK_SECRET: secreto de X-Hub-Signature-256
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_SLUG=roke-platform
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# N8N — automatización de soporte / WhatsApp
# N8N_WEBHOOK_SECRET: token compartido que n8n manda en Authorization: Bearer
# N8N_WEBHOOK_URL: base de webhooks de n8n para disparos salientes (recordatorios)
# ─────────────────────────────────────────────────────────────────────────────
N8N_ENABLED=false
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_URL=
N8N_TIMEOUT=15

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS — hosting platform
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hosting_platform
DB_USERNAME=hosting_user
DB_PASSWORD=secure_password

# roke.pet — base de datos separada (solo comparte la tabla users vía uuid)
ROKEPET_DB_HOST=127.0.0.1
ROKEPET_DB_PORT=3306
ROKEPET_DB_DATABASE=roke_pet
ROKEPET_DB_USERNAME=rokepet_user
ROKEPET_DB_PASSWORD=secure_password

# ─────────────────────────────────────────────────────────────────────────────
# CACHE / COLAS / SESIÓN / BROADCAST
# ─────────────────────────────────────────────────────────────────────────────
BROADCAST_DRIVER=reverb
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
MEMCACHED_HOST=127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# CORREO
# ─────────────────────────────────────────────────────────────────────────────
# Proveedor de correo: Resend (resend/resend-laravel).
# En local usa MAIL_MAILER=log para que los correos se escriban en storage/logs.
MAIL_MAILER=resend
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_ADDRESS=soporte@rokeindustries.com
MAIL_FROM_NAME="${APP_NAME}"

# Fallback SMTP (opcional). Solo se usa si MAIL_MAILER=smtp.
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ─────────────────────────────────────────────────────────────────────────────
# ALMACENAMIENTO — AWS S3 (opcional)
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH — panel de administración (hosting)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE — hosting (ROKE Industries)
# Webhook: /api/stripe/webhook
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_your_stripe_key
STRIPE_SECRET=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# BILLING / FACTURACIÓN
# ─────────────────────────────────────────────────────────────────────────────
BILLING_TAX_RATE_PERCENT=16.00
RECEIPT_PREFIX=REC-

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD / CORS / SANCTUM
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://admin.rokeindustries.dev,https://app.rokeindustries.dev,https://roke.pet,https://www.roke.pet
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:3000,::1,admin.rokeindustries.dev,app.rokeindustries.dev,api.rokeindustries.dev
# En dev/prod con subdominios hermanos puedes usar .rokeindustries.dev.
# En local déjalo en localhost o vacío según tu entorno.
SESSION_DOMAIN=.rokeindustries.dev
SESSION_SECURE_COOKIE=true

# ─────────────────────────────────────────────────────────────────────────────
# REVERB — servidor WebSocket (Laravel)
# ─────────────────────────────────────────────────────────────────────────────
REVERB_APP_ID=hosting-platform
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=api.rokeindustries.dev
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Reverb valida contra el host del Origin. Puedes poner URLs completas aquí;
# config/reverb.php las normaliza a hostnames para evitar "Origin not allowed".
REVERB_ALLOWED_ORIGINS=admin.rokeindustries.dev,app.rokeindustries.dev,*.rokeindustries.dev,*.rokeindustries.com,roke.pet,*.roke.pet

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─────────────────────────────────────────────────────────────────────────────
# PTERODACTYL — game servers
# Application API key (ptla_...) → gestión de servidores/usuarios
# Client API key (ptlc_...)      → métricas, power actions y backups del cliente
# WINGS_INTERNAL_URL: accesible desde el backend (Tailscale/LAN, sin SSL)
# WINGS_PUBLIC_URL:    URL pública para los clientes
# ─────────────────────────────────────────────────────────────────────────────
PTERODACTYL_URL=https://panel.yourdomain.com
PTERODACTYL_API_KEY=your_application_api_key
PTERODACTYL_CLIENT_API_KEY=your_client_api_key
PTERODACTYL_DEFAULT_NODE=1
PTERODACTYL_RELAY_IP=
PTERODACTYL_WINGS_INTERNAL_URL=
PTERODACTYL_WINGS_PUBLIC_URL=https://wings.rokeindustries.com

# ─────────────────────────────────────────────────────────────────────────────
# FRP — reverse proxy para game servers detrás de NAT
# ─────────────────────────────────────────────────────────────────────────────
FRP_HOST=100.94.93.51
FRP_USER=rokeryzen
FRP_LOCAL_IP=100.94.93.51
FRP_CONFIG_PATH=/etc/frp/frpc.toml
FRP_SERVICE_NAME=frpc

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE — gestión de DNS
# API Token: Cloudflare → My Profile → API Tokens (Zone → DNS → Edit)
# Zone ID:   Cloudflare → (dominio) → Overview → API → Zone ID
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=rokeindustries.com
CLOUDFLARE_MINECRAFT_SRV_TARGET=mc.rokeindustries.com
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# FACTURAMA — CFDI 4.0 (facturación electrónica México)
# Credenciales de la cuenta API en app.facturama.mx
# ─────────────────────────────────────────────────────────────────────────────
FACTURAMA_USER=
FACTURAMA_PASSWORD=
FACTURAMA_SANDBOX=true
FACTURAMA_ISSUER_RFC=
FACTURAMA_ISSUER_NAME=
FACTURAMA_ISSUER_REGIMEN=601
FACTURAMA_ISSUER_ZIP=

# ─────────────────────────────────────────────────────────────────────────────
# BACKUPS / NAS (Mac mini)
# Recomendado: montar el share del Mac mini y apuntar NAS_ROOT a esa ruta.
# Para SFTP: NAS_DRIVER=sftp + NAS_SFTP_HOST/USERNAME/PASSWORD/PORT.
# ─────────────────────────────────────────────────────────────────────────────
NAS_DRIVER=local
NAS_ROOT=/mnt/nas/backups
BACKUP_DISK=nas
BACKUP_RETENTION_DAYS=30
BACKUP_MYSQLDUMP_PATH=/usr/bin/mysqldump

# ─────────────────────────────────────────────────────────────────────────────
# roke.pet — GOOGLE OAUTH (credenciales propias)
# Redirect URI: https://tu-backend.rokeindustries.com/api/rp/auth/google/callback
# El VITE_GOOGLE_CLIENT_ID del frontend roke-pet = ROKEPET_GOOGLE_CLIENT_ID
# ─────────────────────────────────────────────────────────────────────────────
ROKEPET_GOOGLE_CLIENT_ID=
ROKEPET_GOOGLE_CLIENT_SECRET=
ROKEPET_GOOGLE_REDIRECT_URL=https://tu-backend.rokeindustries.com/api/rp/auth/google/callback

# roke.pet — Web Push (VAPID). Generar con: npx web-push generate-vapid-keys
ROKEPET_VAPID_PUBLIC_KEY=
ROKEPET_VAPID_PRIVATE_KEY=
ROKEPET_VAPID_SUBJECT=mailto:soporte@rokeindustries.com

# ─────────────────────────────────────────────────────────────────────────────
# FCM (Firebase Cloud Messaging) — push de la app móvil Flutter (roke-pet-app)
# La app registra su token FCM en /api/rp/push/subscribe; el backend envía vía
# FCM HTTP v1, que requiere una cuenta de servicio (service account JSON):
#   1. Firebase Console → proyecto "hosting-plataform" → Configuración del proyecto
#      → Cuentas de servicio → "Generar nueva clave privada".
#   2. Guardar el JSON en cada servidor como: storage/firebase-credentials.json
#   3. FIREBASE_CREDENTIALS = ruta relativa a storage_path() (solo el nombre basta).
# Es el MISMO proyecto Firebase que la app de hosting (com.rokeindustries.client),
# así que la misma cuenta de servicio sirve para ambas apps.
# FCM_PROJECT_ID es opcional: por defecto ya es "hosting-plataform".
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS=firebase-credentials.json
FCM_PROJECT_ID=hosting-plataform

# roke.pet — Stripe
# Hoy comparte la cuenta de ROKE Industries: deja ROKEPET_STRIPE_SECRET VACÍO y usa
# STRIPE_SECRET. Cuando roke.pet sea otra entidad con su propia cuenta, llénalo (sin
# tocar código). El webhook de roke.pet es un endpoint distinto (/api/rp/stripe/webhook)
# y Stripe le da su PROPIO whsec_ → pégalo en ROKEPET_STRIPE_WEBHOOK_SECRET.
ROKEPET_FRONTEND_URL=https://roke.pet
ROKEPET_STRIPE_SECRET=
ROKEPET_STRIPE_WEBHOOK_SECRET=
ROKEPET_STRIPE_PRICE_STARTER=price_xxxxxxxxxxxx
ROKEPET_STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
ROKEPET_TRIAL_DAYS=14

# ─────────────────────────────────────────────────────────────────────────────
# DOCUMENTACIÓN API (Swagger / OpenAPI)
# ─────────────────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_CONTACT_EMAIL=soporte@rokeindustries.com
# SWAGGER_SERVER_URL=https://api.tudominio.com/api

# ─────────────────────────────────────────────────────────────────────────────
# IA DE SOPORTE — ROKE PET (Anthropic / Claude)
# ─────────────────────────────────────────────────────────────────────────────
# La llave vive SÓLO aquí (backend). NUNCA se expone al frontend. Si se deja
# vacía o ROKEPET_AI_SUPPORT_ENABLED=false, el chat sigue funcionando pero cada
# mensaje del cliente escala directo a un agente humano (no se inventan respuestas).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_SUPPORT_MODEL=claude-haiku-4-5
ANTHROPIC_SUPPORT_MAX_TOKENS=700
ANTHROPIC_TIMEOUT=30

ROKEPET_AI_SUPPORT_ENABLED=true
ROKEPET_AI_CONFIDENCE_THRESHOLD=0.55
ROKEPET_AI_KB_TOP_K=3
ROKEPET_AI_HISTORY_LIMIT=12

# ─────────────────────────────────────────────────────────────────────────────
# PLANO DE CÓMPUTO — Mes 3 (annual billing, juegos, observabilidad)
# ─────────────────────────────────────────────────────────────────────────────

# Dominio wildcard de las apps deployadas: {project}-{env}-{hash}.<dominio>.
# Requiere un registro DNS *.apps.rokeindustries.dev → edge (Traefik) de Coolify.
COMPUTE_APP_DOMAIN=apps.rokeindustries.dev

# ── Annual billing — precios de los planes de cómputo ───────────────────────
# Moneda del catálogo (ISO 4217).
COMPUTE_BILLING_CURRENCY=MXN
# Precio por periodo (mensual / cobro anual completo) en la moneda anterior.
# Vacío = "Sin precio" en la UI (NO se interpreta como gratis). 'free' es $0 fijo.
COMPUTE_PRICE_STARTER_MONTHLY=
COMPUTE_PRICE_STARTER_ANNUAL=
COMPUTE_PRICE_PRO_MONTHLY=
COMPUTE_PRICE_PRO_ANNUAL=
COMPUTE_PRICE_TEAM_MONTHLY=
COMPUTE_PRICE_TEAM_ANNUAL=
COMPUTE_PRICE_AGENCY_MONTHLY=
COMPUTE_PRICE_AGENCY_ANNUAL=
# IDs de precio de Stripe por plan×intervalo (price_...), para el checkout.
COMPUTE_STRIPE_STARTER_MONTHLY=
COMPUTE_STRIPE_STARTER_ANNUAL=
COMPUTE_STRIPE_PRO_MONTHLY=
COMPUTE_STRIPE_PRO_ANNUAL=
COMPUTE_STRIPE_TEAM_MONTHLY=
COMPUTE_STRIPE_TEAM_ANNUAL=
COMPUTE_STRIPE_AGENCY_MONTHLY=
COMPUTE_STRIPE_AGENCY_ANNUAL=

# ── Más juegos — egg/nest de Pterodactyl por preset ─────────────────────────
# Importa el egg del juego en tu panel Pterodactyl y pega aquí su egg_id/nest_id.
# Sin configurar, el preset se expone como "próximamente" (available=false).
COMPUTE_GAME_MINECRAFT_EGG=
COMPUTE_GAME_MINECRAFT_NEST=
COMPUTE_GAME_FIVEM_EGG=
COMPUTE_GAME_FIVEM_NEST=
COMPUTE_GAME_RUST_EGG=
COMPUTE_GAME_RUST_NEST=
COMPUTE_GAME_PALWORLD_EGG=
COMPUTE_GAME_PALWORLD_NEST=
COMPUTE_GAME_VALHEIM_EGG=
COMPUTE_GAME_VALHEIM_NEST=

# ── Observabilidad (mes 2/3) ────────────────────────────────────────────────
# Sentry (errores backend). Vacío = no-op. Horizon requiere QUEUE_CONNECTION=redis.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
