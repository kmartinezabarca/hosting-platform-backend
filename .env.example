APP_NAME="ROKE Industries"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
COMPANY_LOGO_URL="${APP_URL}/server-icon.png"
COOLIFY_URL=http://100.94.93.51:8000
COOLIFY_API_TOKEN=
COOLIFY_TEAM_ID=0
COOLIFY_SERVER_UUID=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hosting_platform
DB_USERNAME=hosting_user
DB_PASSWORD=secure_password

# roke.pet — base de datos separada
ROKEPET_DB_HOST=127.0.0.1
ROKEPET_DB_PORT=3306
ROKEPET_DB_DATABASE=roke_pet
ROKEPET_DB_USERNAME=rokepet_user
ROKEPET_DB_PASSWORD=secure_password

# roke.pet — Google OAuth
# Crear en: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI autorizado: https://tu-backend.rokeindustries.com/api/rp/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://tu-backend.rokeindustries.com/api/rp/auth/google/callback

# roke.pet — Web Push (VAPID)
# Generar con: npx web-push generate-vapid-keys
ROKEPET_VAPID_PUBLIC_KEY=
ROKEPET_VAPID_PRIVATE_KEY=
ROKEPET_VAPID_SUBJECT=mailto:soporte@rokeindustries.com

# roke.pet — Stripe
# Crear precios en: dashboard.stripe.com → Products → Add product
ROKEPET_FRONTEND_URL=https://roke.pet
ROKEPET_STRIPE_PRICE_STARTER=price_xxxxxxxxxxxx
ROKEPET_STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
ROKEPET_TRIAL_DAYS=14

BROADCAST_DRIVER=reverb
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=sendgrid
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_sendgrid_api_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=soporte@rokeindustries.com
MAIL_FROM_NAME="${APP_NAME}"

# SendGrid Configuration
SENDGRID_API_KEY=SG.example_api_key_here

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Proxmox Configuration
PROXMOX_URL=https://proxmox.yourdomain.com:8006
PROXMOX_USERNAME=api@pve
PROXMOX_PASSWORD=secure_api_password
PROXMOX_DEFAULT_NODE=pve

# Pterodactyl Configuration
PTERODACTYL_URL=https://panel.yourdomain.com
# Application API key (ptla_...) — gestión de servidores/usuarios
PTERODACTYL_API_KEY=your_application_api_key
# Client API key (ptlc_...) — métricas, power actions y BACKUPS del cliente
# Crear en el panel: Account → API Credentials (con cuenta admin)
PTERODACTYL_CLIENT_API_KEY=your_client_api_key

# Domain Registrar Configuration (Namecheap)
NAMECHEAP_API_USER=your_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_CLIENT_IP=your_server_ip
NAMECHEAP_SANDBOX=true

# Payment Gateway Configuration
STRIPE_KEY=pk_test_your_stripe_key
STRIPE_SECRET=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Application Settings
DEFAULT_CURRENCY=USD
DEFAULT_COUNTRY=US
RECEIPT_PREFIX=REC-
INVOICE_PREFIX=INV-
TICKET_PREFIX=TKT-

# Security Settings
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:3000,::1,yourdomain.com
SESSION_DOMAIN=.yourdomain.com


# Pusher Configuration (for real-time notifications and chat)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

# Reverb Configuration (Laravel WebSocket Server)
REVERB_APP_ID=hosting-platform
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

 --- SECCIÓN DE PUSHER (OPCIONAL) ---
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=
PUSHER_SCHEME=
PUSHER_APP_CLUSTER=

# Proxmox Configuration
PROXMOX_URL=https://proxmox.yourdomain.com:8006
PROXMOX_USERNAME=api@pve
PROXMOX_PASSWORD=secure_api_password
PROXMOX_DEFAULT_NODE=pve

# Pterodactyl Configuration
PTERODACTYL_URL=https://panel.yourdomain.com
# Application API key (ptla_...) — gestión de servidores/usuarios
PTERODACTYL_API_KEY=your_application_api_key
# Client API key (ptlc_...) — métricas, power actions y BACKUPS del cliente
# Crear en el panel: Account → API Credentials (con cuenta admin)
PTERODACTYL_CLIENT_API_KEY=your_client_api_key

# Domain Registrar Configuration (Namecheap)
NAMECHEAP_API_USER=your_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_CLIENT_IP=your_server_ip
NAMECHEAP_SANDBOX=true

# Payment Gateway Configuration
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Application Settings
DEFAULT_CURRENCY=MXN
DEFAULT_COUNTRY=MX
DEFAULT_TIMEZONE=America/Mexico_City
RECEIPT_PREFIX=REC-
INVOICE_PREFIX=INV-
TICKET_PREFIX=TKT-

# Billing Settings
BILLING_TAX_RATE_PERCENT=16.00
APP_DEBUG_GEOIP_IP=201.141.XX.XX

# Security Settings
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://roke.pet,https://www.roke.pet
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# API Documentation (Swagger/OpenAPI)
SWAGGER_ENABLED=true
SWAGGER_CONTACT_EMAIL=soporte@rokeindustries.com
# SWAGGER_SERVER_URL=https://api.tudominio.com/api

# Backups / NAS (Mac mini)
# Recomendado: montar el share del Mac mini y apuntar NAS_ROOT a esa ruta.
NAS_DRIVER=local
NAS_ROOT=/mnt/nas/backups
BACKUP_DISK=nas
BACKUP_RETENTION_DAYS=30
# Si usas SFTP en lugar de carpeta montada:
# NAS_DRIVER=sftp
# NAS_SFTP_HOST=
# NAS_SFTP_USERNAME=
# NAS_SFTP_PASSWORD=
# NAS_SFTP_PORT=22
